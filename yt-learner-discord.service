[Unit]
Description=yt-learner Discord bot
After=network.target

[Service]
Type=simple
User=deepanshu
EnvironmentFile=/home/deepanshu/.env
WorkingDirectory=/home/deepanshu/projects/yt-learner
ExecStart=/home/deepanshu/.local/bin/uv run yt-learner-discord
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
